
@{
    
  ViewData["Title"] = "About Page";
}



<!-- Hero Section - Updated Attractive Version -->
<section>
    <div style="height:400px">
        <div class="carousel-inner">
            <div class="carousel-item active"
                 style="background-image: url('images/head3.png'); height:400px">
                <div class="carousel-caption">
                  <div style="margin-bottom:50px"><br /><br /></div>
                    <h3>About Jannat Garden</h3>
                    <p>Perfect Venue for Your Special Day</p>
                    
                </div>
            </div>
         
        </div>
       
    </div>
</section>
<!-- About -->
<section id="about" class="py-5 fade-section" style="background: #fdfaf5; position: relative; overflow: hidden;">
    <!-- Background watermark text -->
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 18rem; font-weight: 900; color: rgba(184, 134, 11, 0.06); pointer-events: none; user-select: none; white-space: nowrap; z-index: 0; font-family: 'Playfair Display', serif;">
        JANNAT GARDEN
    </div>

    <div class="container position-relative" style="z-index: 1;">

        <div class="row justify-content-center align-items-center g-5">
            <!-- Text Column -->
            <div class="col-lg-6">
                <div style="background: rgba(255, 255, 255, 0.9); padding: 40px 35px; border-radius: 15px; box-shadow: 0 10px 35px rgba(0,0,0,0.08); border: 1px solid rgba(184, 134, 11, 0.15);">
                    <h5 style="font-size: 1.8rem; color: var(--gold); font-weight: 700; letter-spacing: 2px; margin-bottom: 0.5rem;">About Jannat Garden</h5>
                    <p style="text-align:justify">
                        Step into <strong>Jannat Garden</strong> and be welcomed by the serene beauty of
                        river-facing elegance and heartfelt hospitality.
                    </p>
                    <p style="text-align:justify"> Jannat Garden is a premium wedding and event destination offering a beautiful lawn, elegant décor, and modern facilities to make your celebrations unforgettable.</p>
                    <p style="text-align:justify">
                        Our promise is simple — to turn your special day into an unforgettable celebration by taking
                        care of every minute detail, ensuring flawless execution, and letting love, laughter, and
                        joy flow naturally.
                    </p>
                </div>
            </div>

            <!-- Decorative Image Frame Column -->
            <div class="col-lg-6 text-center">
                <div style="position: relative; padding: 25px; background: linear-gradient(135deg, #fdfaf5, #fffaf0); border-radius: 20px; box-shadow: 0 15px 40px rgba(0,0,0,0.12); border: 8px solid #fff;">
                    <!-- Ornamental border simulation -->
                    <div style="position: absolute; top: -18px; left: 50%; transform: translateX(-50%); font-size: 4.5rem; color: var(--gold); opacity: 0.9;">
                        ♔
                    </div>
                    <div style="position: absolute; bottom: -18px; left: 50%; transform: translateX(-50%); font-size: 4.5rem; color: var(--gold); opacity: 0.9;">
                        ♔
                    </div>

                    <img src="images/20.jpeg"
                         alt="Jannat Garden Celebration"
                         style="width: 100%; border-radius: 12px; box-shadow: 0 8px 25px rgba(0,0,0,0.15);">
                </div>
            </div>
        </div>

      
    </div>


</section>

