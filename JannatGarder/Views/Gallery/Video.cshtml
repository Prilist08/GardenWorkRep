

@{
    ViewData["Title"] = "Video Page";
}

<section id="home">
    <div id="headerCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="6000">
        <div class="carousel-inner">
            <div class="carousel-item active"
                 style="background-image: url('https://eventalistanddecor.com/wp-content/uploads/2025/07/Premium-Wedding-Stage-Decoration.jpeg');">
                <div class="carousel-caption">
                    <h1>Welcome to Jannat Garden</h1>
                    <p>River Facing Banquet Hall • Perfect Venue for Your Special Day</p>
                    <a href="#" class="btn btn-light btn-lg mt-4 px-5 shadow-lg" data-bs-toggle="modal"
                       data-bs-target="#contactModal">Enquire Now</a>
                </div>
            </div>
            <div class="carousel-item"
                 style="background-image: url('https://thumbs.dreamstime.com/b/opulent-indian-wedding-stage-vibrant-floral-decor-opulent-indian-wedding-stage-lavishly-decorated-vibrant-fresh-420798580.jpg');">
                <div class="carousel-caption">
                    <h1>Grand Celebrations</h1>
                    <p>Stunning Decor • Riverside Beauty</p>
                    <a href="#gallery" class="btn btn-light btn-lg mt-4 px-5 shadow-lg">View Gallery</a>
                </div>
            </div>
            <div class="carousel-item"
                 style="background-image: url('https://blog.venuelook.com/wp-content/uploads/2024/06/Cultural-and-Themed-Wedding-Stage-Ideas.jpg');">
                <div class="carousel-caption">
                    <h1>Create Memories</h1>
                    <p>Affordable Luxury • Magical Atmosphere</p>
                    <a href="#" class="btn btn-light btn-lg mt-4 px-5 shadow-lg" data-bs-toggle="modal"
                       data-bs-target="#contactModal">Contact Us</a>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#headerCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#headerCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</section>
<!-- Videos -->
<section id="videos" class="py-5 fade-section">
    <div class="container">
        <h2 class="text-center mb-5">Watch Our Venue</h2>
        <div class="row g-5 justify-content-center">
            <div class="col-md-6">
                <div class="video-wrapper">
                    <video controls>
                        <source src="images/v1.mp4" type="video/mp4">
                    </video>
                </div>
            </div>
            <div class="col-md-6">
                <div class="video-wrapper">
                    <video controls>
                        <source src="images/v2.mp4" type="video/mp4">
                    </video>
                </div>
            </div>
        </div>
    </div>
</section>