<section>
    <div style="height:400px">
        <div class="carousel-inner">
            <div class="carousel-item active"
                 style="background-image: url('images/head3.png'); height:400px">
                <div class="carousel-caption">
                    <div style="margin-bottom:50px"><br /><br /></div>
                    <h3>Venue- Jannat Garden</h3>
                    <p>Perfect Venue for Your Special Day</p>

                </div>
            </div>

        </div>

    </div>
</section>

<section id="Perfect" class="py-5 fade-section" style="background: #fdfaf5; position: relative; overflow: hidden;">
    <!-- Background watermark text -->
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 18rem; font-weight: 900; color: rgba(184, 134, 11, 0.06); pointer-events: none; user-select: none; white-space: nowrap; z-index: 0; font-family: 'Playfair Display', serif;">

        🌿 Our Venue – Jannat Garden
    </div>

    <div class="container position-relative" style="z-index: 1;">

        <div class="row justify-content-center align-items-center g-5">
            <!-- Text Column -->
            <div class="col-lg-12">
                <div style="background: rgba(255, 255, 255, 0.9); padding: 40px 35px; border-radius: 15px; box-shadow: 0 10px 35px rgba(0,0,0,0.08); border: 1px solid rgba(184, 134, 11, 0.15);">

                    <h5 style="font-size: 1.8rem; color: var(--gold); font-weight: 700; letter-spacing: 2px; margin-bottom: 0.5rem;">🌿 Our Venue – Jannat Garden</h5>

                    <p style="text-align:justify">
                        Welcome to Jannat Garden, a perfect destination for weddings, receptions, corporate events, and grand celebrations. Our venue is designed to offer elegance, comfort, and modern facilities — all in one place.
                        Spread across a spacious and well-maintained lawn, Jannat Garden offers:

                    </p>
                    <p style="text-align:justify">At Jannat Garden, we offer a spacious, elegant, and fully-equipped venue designed to make every celebration grand and memorable. From large weddings to corporate gatherings, our venue provides the perfect blend of beauty and functionality.</p>
                </div>
            </div>

        </div>


    </div>


</section>
<!-- === FINAL EVENTS SECTION - ONLY BORDER DESIGNS, NO INSIDE FLOWER/BUTTERFLY ON IMAGES === -->
<section id="events" class="py-5">
    <div class="container">
        <!-- Event 1: Wedding & Reception - Marigold Floral Garland Border -->
        <div class="row align-items-center"
             style="background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 50%, #fce4ec 100%); border-radius: 25px; padding: 40px 20px; box-shadow: 0 15px 40px rgba(212,175,55,0.15);">
            <div class="col-lg-5">
                <div class="event-text p-8">
                    <h4 style="color: var(--gold); font-weight: 700; margin-bottom: 15px;font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif">
                        Celebrate your special moments-
                    </h4>
                    <p style="text-align:justify">

                        Spread across a spacious and well-maintained lawn, Jannat Garden offers:
                        <ul>
                            <li>
                                🌳 Lush green garden ambiance
                            </li>

                            <li> 🏛️ Stylish décor and lighting arrangements</li>

                            <li> ❄️ Comfortable seating & covered areas</li>

                            <li>  🚗 Ample parking space</li>

                            <li>  ⚡ Power backup & modern amenities</li>
                        </ul>
                    </p>
                </div>
            </div>
            <div class="col-lg-7">
                <section id="eventSp">
                    <div id="engagementCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="6000">
                        <div class="carousel-inner">
                            <div class="carousel-item active"
                                 style="background-image: url('images/2.jpeg');">

                                >
                                <div class="carousel-caption">

                                    <p>Perfect for day & night events</p>

                                </div>
                            </div>
                            <div class="carousel-item"
                                 style="background-image: url('images/22.jpeg');">
                                <div class="carousel-caption">

                                    <p>Wide open green area</p>

                                </div>
                            </div>
                            <div class="carousel-item"
                                 style="background-image: url('images/20.jpeg');">
                                <div class="carousel-caption">

                                    <p>Ideal for stage setup & décor themes</p>
                                    <a href="#gallery" class="btn btn-light btn-lg mt-4 px-5 shadow-lg">Get More</a>
                                </div>
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#headerCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#headerCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    </div>
                </section>
            </div>
        </div>

    </div>
</section>




<section id="venue" class="venue-section">
    <div class="container">
        <h2 style="text-align: center; margin-bottom: 30px">Our Venue</h2>
        <p></p>
        <div class="venues-grid">
            <!-- Garden Lawn -->
            <div id="garden" class="venue-card animate-slide">
                <div class="image-wrapper flower-border">
                    <img src="~/images/12.jpeg"
                         alt="Garden Lawn">
                </div>
                <div class="venue-content">
                    <h3>Grand Open Lawn</h3>
                   @*  <p class="theme">Dreamy Outdoor Romance</p>
                    <p style="align-content:flex-start">
                        Our beautifully maintained green lawn is ideal for hosting large-scale events with comfort and style.
                        <ul>
                            <li>
                                Capacity: Up to 800–1000 Guests
                            </li>

                            <li>  Wide & Open Layout for flexible setup</li>

                            <li>   Perfect for wedding stages & mandap setup</li>

                            <li>  Suitable for day & night functions</li>
                        </ul>
                        The open sky ambiance combined with decorative lighting creates a magical atmosphere for unforgettable celebrations.
                    </p> *@
                </div>
            </div>
            <!-- AC Banquet Hall -->
            <div id="banquet" class="venue-card animate-slide" style="animation-delay: 0.2s;">
                <div class="image-wrapper flower-border">
                    <img src="images/15.jpeg"
                         alt="AC Banquet Hall">
                </div>
                <div class="venue-content">
                    <h3>AC Banquet Hall</h3>
                  @*   <p class="theme">Royal & Luxurious Grand</p>
                    <p>
                        Crystal chandeliers, AC comfort, badi dance floor aur shahi vibe. Evening receptions, baraat
                        ya bada function ke liye perfect – 800+ guests tak aaram se.
                    </p> *@
                </div>
            </div>
            <!-- Premium Seating Hall -->
            <div id="seating" class="venue-card animate-slide" style="animation-delay: 0.4s;">
                <div class="image-wrapper flower-border">
                    <img src="images/16.jpeg"
                         alt="Premium Seating Hall">
                </div>
                <div class="venue-content">
                    <h3> Seating Hall</h3>
                   @*  <p class="theme">Modern Elegant Charm</p>
                    <p>
                        Flexible seating, beautiful lighting, stage customisation. Mehendi, haldi, ring ceremony ya
                        chhote receptions ke liye ideal – 200-500 guests.
                    </p> *@
                </div>
            </div>
            <!-- Extra images for better look (small previews) -->
           @*  <div class="extra-images animate-fade">
                <div class="small-img flower-border-small">
                    <img src="images/18.jpeg"
                         alt="Garden Extra">
                </div>
                <div class="small-img flower-border-small">
                    <img src="~/images/14.jpeg"
                         alt="Banquet Extra">
                </div>
                <div class="small-img flower-border-small">
                    <img src="http://www.marriagecolours.com/wp-content/uploads/2025/10/Barath-Manimaran-Stephna-Victor-Reception-Apl-25-Leela-Palace-8.jpg"
                         alt="Seating Extra">
                </div>
                <div class="small-img flower-border-small">
                    <img src="http://www.marriagecolours.com/wp-content/uploads/2025/10/Barath-Manimaran-Stephna-Victor-Reception-Apl-25-Leela-Palace-8.jpg"
                         alt="Seating Extra">
                </div>

            </div> *@
        </div>
    </div>
</section>
