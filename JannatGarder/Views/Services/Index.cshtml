

@{
    ViewData["Title"] = "Services";
}
<!-- Topbar -->


<section>
    <div style="height:400px">
        <div class="carousel-inner">
            <div class="carousel-item active"
                 style="background-image: url('images/head3.png'); height:400px">
                <div class="carousel-caption">
                    <div style="margin-bottom:50px"><br /><br /></div>
                    <h3>Services- Jannat Garden</h3>
                    <p>Perfect Venue for Your Special Day</p>

                </div>
            </div>

        </div>

    </div>
</section>
<!-- === NEW ELEGANT SERVICES SECTION - WEDDING INSPIRED === -->
<section id="services" class="services-new py-5 fade-section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 style="text-align: center; margin-bottom: 30px">Our Services</h2>


        </div>


        <div class="row g-5 justify-content-center">
            <div class="col-lg-4 col-md-6">
                <div class="service-item">
                    <div class="service-icon"><i class="fas fa-landmark"></i></div>
                    <h5>Spacious Banquet Hall</h5>
                    <p>
                        River-facing grand space with luxurious AC comfort aur 800+ guests ke liye shahi
                        seating.
                    </p>
                </div>
            </div>


            <div class="col-lg-4 col-md-6">
                <div class="service-item">
                    <div class="service-icon"><i class="fas fa-palette"></i></div>
                    <h5>Theme Decorations</h5>
                    <p>
                        Custom mandap, floral wonders, LED backdrops aur aapke sapno ke theme ke mutabik
                        design.
                    </p>
                </div>
            </div>


            <div class="col-lg-4 col-md-6">
                <div class="service-item">
                    <div class="service-icon"><i class="fas fa-lightbulb"></i></div>
                    <h5>Premium Lighting</h5>
                    <p>
                        Crystal chandeliers, fairy lights aur romantic glow ke saath stunning ambiance
                        creation.
                    </p>
                </div>
            </div>


            <div class="col-lg-4 col-md-6">
                <div class="service-item">
                    <div class="service-icon"><i class="fas fa-music"></i></div>
                    <h5>Sound & DJ System</h5>
                    <p>High-end sound, professional DJ aur sangeet-baraat ke liye powerful audio setup.</p>
                </div>
            </div>


            <div class="col-lg-4 col-md-6">
                <div class="service-item">
                    <div class="service-icon"><i class="fas fa-utensils"></i></div>
                    <h5>Catering Support</h5>
                    <p>
                        Best caterers, multi-cuisine menus aur live counters ke saath delicious arrangements.
                    </p>
                </div>
            </div>


            <div class="col-lg-4 col-md-6">
                <div class="service-item">
                    <div class="service-icon"><i class="fas fa-concierge-bell"></i></div>
                    <h5>Event Management</h5>
                    <p>
                        Planning se execution tak full team support – stress-free aur flawless celebrations.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>



